# OffTrail production data providers.
# Do not commit real values. Copy this file to .env.local and fill the keys there.

# Browser-safe key used only for client-side static map/photo previews when needed.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-side Google key. Enable Routes API, Places API (New), Geocoding API, and Static Maps API.
GOOGLE_MAPS_API_KEY=

# Optional: separate Google Places key. If omitted, GOOGLE_MAPS_API_KEY is used.
GOOGLE_PLACES_API_KEY=

# Optional supplemental provider for richer places/photos.
FOURSQUARE_API_KEY=

# Optional copy enhancement. The app works without it.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Optional saved routes/favorites persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local sample previews only. Production should keep this false so OffTrail only shows verified routes.
OFFTRAIL_ALLOW_ESTIMATED_ROUTES=false
