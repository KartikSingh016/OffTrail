# OffTrail production data providers.
# Do not commit real values. Copy this file to .env.local and fill the keys there.

# Cost safety: keep every paid provider off until you intentionally enable and quota-cap it.
OFFTRAIL_ENABLE_PAID_PROVIDERS=false
OFFTRAIL_ENABLE_AI_ENRICHMENT=false
OFFTRAIL_ENABLE_HOSTED_PERSISTENCE=false
NEXT_PUBLIC_OFFTRAIL_ENABLE_PAID_MAP_PREVIEWS=false

# Browser-safe key used only for client-side static map previews when the preview flag above is true.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-side Google key. Enable only after Google Cloud quotas and budget alerts are configured.
GOOGLE_MAPS_API_KEY=

# Optional: separate Google Places key. If omitted, GOOGLE_MAPS_API_KEY is used.
GOOGLE_PLACES_API_KEY=

# Optional supplemental provider for richer places/photos.
FOURSQUARE_API_KEY=

# Optional copy enhancement. The app works without it.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Optional saved routes/favorites persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local sample previews only. Production should keep this false so OffTrail only shows verified routes.
OFFTRAIL_ALLOW_ESTIMATED_ROUTES=false
